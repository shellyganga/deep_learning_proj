{
  "datasets": [
    "SciFact",
    "NFCorpus",
    "FiQA2018",
    "TRECCOVID"
  ],
  "embeddings": [
    "AML12v2",
    "ME5S",
    "MQML6Cv1",
    "E5Sv2"
  ],
  "strategies": [
    "recur",
    "langchain",
    "chonkie",
