  "intrinsic_extrinsic_correlation": {
    "pearson_r": 0.85,
    "n_pairs": 12,
    "intrinsic_axis": "macro_avg",
    "extrinsic_axis": "ndcg@10_avg_across_embeddings",
    "excluded": "fixed-size baseline (not in retrieval_aggregate.csv)"
